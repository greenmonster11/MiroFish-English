# LLM API Configuration (supports any OpenAI SDK-compatible API)
# Using OpenAI gpt-4o-mini for best cost efficiency (~$2 per full simulation)
# Get your key at: https://platform.openai.com/api-keys
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# ===== Zep Memory Graph Configuration =====
# Free monthly quota is sufficient for basic usage
# Sign up at: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Configuration (Optional) =====
# If not using boost config, remove these lines entirely
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
